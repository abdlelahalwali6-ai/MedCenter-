rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL HELPERS & CONSTANTS
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "abdlelahalwali6@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }
    
    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['doctor', 'nurse', 'pharmacist', 'lab_tech', 'receptionist', 'radiologist'])
      );
    }

    function isOwner(patientId) {
      return isSignedIn() && (
        request.auth.uid == patientId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientId == patientId)
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // CATCH-ALL DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || (uid == request.auth.uid && incoming().role == 'patient'));
      allow update: if isSignedIn() && (isAdmin() || uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if isStaff() || isOwner(patientId);
      allow create, update: if isStaff() || isOwner(patientId);
      allow delete: if isAdmin();
    }

    match /lab_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /radiology_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /lab_requests/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /radiology_requests/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /prescriptions/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow read: if isStaff() || (isSignedIn() && (existing().patientId == request.auth.uid || existing().doctorId == request.auth.uid));
      allow create, update: if isStaff() || (isSignedIn() && incoming().patientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /medical_records/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /bills/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /inventory/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || (isStaff() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "pharmacist");
    }

    match /messages/{id} {
      allow read: if isStaff() || (isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid));
      allow create: if isSignedIn() && (!('senderId' in incoming()) || incoming().senderId == request.auth.uid);
      allow update: if isStaff() || (isSignedIn() && (existing().receiverId == request.auth.uid || existing().senderId == request.auth.uid));
    }

    match /service_requests/{id} {
      allow read: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
