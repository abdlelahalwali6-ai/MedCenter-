rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL HELPERS & CONSTANTS
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == "abdlelahalwali6@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == "admin")
      );
    }
    
    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role in ['doctor', 'nurse', 'pharmacist', 'lab_tech', 'receptionist', 'radiologist'])
      );
    }

    function isOwner(patientId) {
      return isSignedIn() && (
        request.auth.uid == patientId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().patientId == patientId)
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.uid is string && data.uid.size() <= 64 &&
             data.email is string && data.email.size() <= 100 &&
             data.role is string &&
             data.createdAt == request.time;
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['name', 'mrn', 'phone', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.mrn is string && data.mrn.size() > 0 && data.mrn.size() <= 20 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 20 &&
             data.createdAt == request.time;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'doctorId', 'date', 'status', 'createdAt']) &&
             data.patientId is string && data.patientId.size() <= 64 &&
             data.doctorId is string && data.doctorId.size() <= 64 &&
             data.status is string &&
             data.createdAt == request.time;
    }

    // Relational Check
    function patientExists(id) {
      return exists(/databases/$(database)/documents/patients/$(id));
    }

    // ===============================================================
    // CATCH-ALL DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    match /_connection_test_/ping {
      allow read, write: if true;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{uid} {
      allow list: if isStaff();
      allow get: if isSignedIn() && (request.auth.uid == uid || isStaff());
      
      allow create: if isSignedIn() && isValidId(uid) && (
        isAdmin() || 
        (uid == request.auth.uid && incoming().role == 'patient' && isValidUser(incoming()))
      );
      
      allow update: if isSignedIn() && isValidId(uid) && (
        isAdmin() || 
        (uid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber']))
      );
      
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow list: if isStaff();
      allow get: if isValidId(patientId) && (isStaff() || isOwner(patientId));
      allow create: if isStaff() && isValidId(patientId) && isValidPatient(incoming());
      allow update: if isStaff() && isValidId(patientId) && 
                    incoming().mrn == existing().mrn && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'gender', 'dateOfBirth', 'bloodType', 'updatedAt', 'address', 'nationalId']);
      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow list: if isStaff() || (isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid));
      allow get: if isValidId(id) && (isStaff() || (isSignedIn() && (existing().patientId == request.auth.uid || existing().doctorId == request.auth.uid)));
      allow create: if isValidId(id) && (isStaff() || (isSignedIn() && incoming().patientId == request.auth.uid)) && 
                    isValidAppointment(incoming()) && patientExists(incoming().patientId);
      allow update: if isValidId(id) && (isStaff() || (isSignedIn() && existing().patientId == request.auth.uid)) && (
        (existing().status != 'completed' && existing().status != 'cancelled') || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /medical_records/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isValidId(id) && (isStaff() || (isSignedIn() && existing().patientId == request.auth.uid));
      allow create: if isStaff() && isValidId(id) && patientExists(incoming().patientId);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /bills/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isValidId(id) && (isStaff() || (isSignedIn() && existing().patientId == request.auth.uid));
      allow create: if isStaff() && isValidId(id) && patientExists(incoming().patientId);
      allow update: if isStaff() && (existing().status != 'paid' || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventory/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(id);
    }

    match /messages/{id} {
      allow list: if isStaff() || (isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid));
      allow get: if isValidId(id) && (isStaff() || (isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid)));
      allow create: if isSignedIn() && isValidId(id) && (!('senderId' in incoming()) || incoming().senderId == request.auth.uid);
      allow update: if isValidId(id) && (isStaff() || (isSignedIn() && (existing().receiverId == request.auth.uid || existing().senderId == request.auth.uid)));
    }

    match /emergency_cases/{id} {
      allow list, get: if isStaff();
      allow create: if isStaff() && isValidId(id);
      allow update: if isStaff() && isValidId(id);
      allow delete: if isAdmin();
    }

    match /wards/{id} {
      allow list, get: if isStaff();
      allow create: if isStaff() && isValidId(id);
      allow update: if isStaff() && isValidId(id);
      allow delete: if isAdmin();
    }

    match /lab_catalog/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /radiology_catalog/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /services_catalog/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /lab_requests/{id} { 
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff();
      allow create, update: if isStaff();
    }
    match /radiology_requests/{id} { 
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff();
      allow create, update: if isStaff();
    }
    match /prescriptions/{id} { 
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff();
      allow create, update: if isStaff();
    }
    match /service_requests/{id} { 
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff();
      allow create, update: if isStaff();
    }
    match /audit_logs/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /settings/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /metadata/{id} { allow read: if isSignedIn(); allow write: if isStaff(); }
  }
}
