rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL HELPERS & CONSTANTS
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    
    // Cache the user document to avoid multiple lookups
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user is an admin
    function isAdmin() { 
      // Auth tokens NEVER contain custom claims in this environment. 
      // Must look up roles using get() or exists() on a trusted database document.
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == "abdlelahalwali6@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == "admin")
      );
    }
    
    // Check if user is a staff member
    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role in ['doctor', 'nurse', 'pharmacist', 'lab_tech', 'receptionist', 'radiologist'])
      );
    }

    // Check if the document belongs to the signed-in patient
    function isOwner(patientId) {
      return isSignedIn() && (
        request.auth.uid == patientId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().patientId == patientId)
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.email is string && data.role is string &&
             data.createdAt == request.time;
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['name', 'mrn', 'phone', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.mrn is string && data.mrn.size() <= 20 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.createdAt == request.time;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'doctorId', 'date', 'status', 'createdAt']) &&
             data.patientId is string && data.doctorId is string && data.status is string &&
             data.createdAt == request.time;
    }

    function isValidMedicalRecord(data) {
      return data.keys().hasAll(['patientId', 'doctorId', 'diagnosis', 'createdAt']) &&
             data.patientId is string && data.doctorId is string && data.diagnosis is string &&
             data.createdAt == request.time;
    }

    function isValidBill(data) {
      return data.keys().hasAll(['patientId', 'totalAmount', 'status', 'createdAt']) &&
             data.patientId is string && data.totalAmount is number && data.status is string &&
             data.createdAt == request.time;
    }

    function isValidEmergencyCase(data) {
      return data.keys().hasAll(['patientName', 'priority', 'status', 'createdAt']) &&
             data.patientName is string && data.priority is string && data.status is string &&
             data.createdAt == request.time;
    }

    function isValidWardBed(data) {
      return data.keys().hasAll(['floor', 'roomNumber', 'bedNumber', 'status', 'updatedAt']) &&
             data.floor is number && data.roomNumber is string && data.bedNumber is number &&
             data.status is string && data.updatedAt == request.time;
    }

    // ===============================================================
    // CATCH-ALL DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity test path
    match /_connection_test_/ping {
      allow read, write: if true;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{uid} {
      allow list: if isStaff() || (!isSignedIn() && request.query.limit <= 1);
      allow get: if isSignedIn() && (request.auth.uid == uid || isStaff());
      
      allow create: if isSignedIn() && (
        isAdmin() || 
        (uid == request.auth.uid && incoming().role == 'patient' && isValidUser(incoming()))
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (uid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber']))
      );
      
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow list: if isStaff() || (isSignedIn() && resource.data.id == request.auth.uid);
      allow get: if isStaff() || isOwner(patientId);
      allow create: if isStaff() && isValidPatient(incoming());
      allow update: if isStaff() && incoming().mrn == existing().mrn && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'gender', 'dateOfBirth', 'bloodType', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /lab_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /radiology_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /lab_requests/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /radiology_requests/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /prescriptions/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow list: if isStaff() || (isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid));
      allow get: if isStaff() || (isSignedIn() && (existing().patientId == request.auth.uid || existing().doctorId == request.auth.uid));
      allow create: if (isStaff() || (isSignedIn() && incoming().patientId == request.auth.uid)) && isValidAppointment(incoming());
      allow update: if (isStaff() || (isSignedIn() && existing().patientId == request.auth.uid)) && (
        existing().status != 'completed' || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /medical_records/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff() && isValidMedicalRecord(incoming());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /bills/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff() && isValidBill(incoming());
      allow update: if isStaff() && (existing().status != 'paid' || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventory/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /messages/{id} {
      allow list: if isStaff() || (isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid));
      allow get: if isStaff() || (isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid));
      allow create: if isSignedIn() && (!('senderId' in incoming()) || incoming().senderId == request.auth.uid);
      allow update: if isStaff() || (isSignedIn() && (existing().receiverId == request.auth.uid || existing().senderId == request.auth.uid));
    }

    match /emergency_cases/{id} {
      allow list, get: if isStaff();
      allow create: if isStaff() && isValidEmergencyCase(incoming());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /wards/{id} {
      allow list, get: if isStaff();
      allow create: if isStaff() && isValidWardBed(incoming());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /service_requests/{id} {
      allow list: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && existing().patientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
